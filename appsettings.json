{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "Yarp.ReverseProxy": "Information"
        }
    },
    "AllowedHosts": "*",
    "ReverseProxy": {
        "Routes": {
            // --- Rutas para UsuariosController ---
            "CrearUsuarioRoute": {
                "ClusterId": "ServicioUsuariosCluster",
                "Match": {
                    "Path": "/api/Usuarios",
                    "Methods": [ "POST" ]
                }
            },
            "ConfirmarCuentaRoute": {
                "ClusterId": "ServicioUsuariosCluster",
                "Match": {
                    "Path": "/api/Usuarios/confirmar",
                    "Methods": [ "PATCH" ]
                }
            },
            "CambiarPasswordRoute": {
                "ClusterId": "ServicioUsuariosCluster",
                "Match": {
                    "Path": "/api/Usuarios/cambiar-password",
                    "Methods": [ "PATCH" ]
                }
            },
            "ActualizarPerfilRoute": {
                "ClusterId": "ServicioUsuariosCluster",
                "Match": {
                    "Path": "/api/Usuarios/actualizar-perfil",
                    "Methods": [ "PUT" ]
                }
            },
            "GetUsuarioByIdRoute": {
                "ClusterId": "ServicioUsuariosCluster",
                "Match": {
                    "Path": "/api/Usuarios/{id}",
                    "Methods": [ "GET" ]
                }
            },
            "SolicitarRecuperacionRoute": {
                "ClusterId": "ServicioUsuariosCluster",
                "Match": {
                    "Path": "/api/Usuarios/solicitar-recuperacion",
                    "Methods": [ "POST" ]
                }
            },
            "RestablecerPasswordRoute": {
                "ClusterId": "ServicioUsuariosCluster",
                "Match": {
                    "Path": "/api/Usuarios/restablecer-password",
                    "Methods": [ "PATCH" ]
                }
            },
            "ObtenerHistorialUsuarioRoute": {
                "ClusterId": "ServicioUsuariosCluster",
                "Match": {
                    "Path": "/api/Usuarios/{usuarioId}/historial",
                    "Methods": [ "GET" ]
                }
            },
            "ObtenerTodasLasActividadesRoute": {
                "ClusterId": "ServicioUsuariosCluster",
                "Match": {
                    "Path": "/api/Usuarios/actividades",
                    "Methods": [ "GET" ]
                }
            },
            // --- FIN Rutas para UsuariosController ---

            // --- Ruta para Todos (JSONPlaceholder) ---
            "todos-get-by-id": {
                "ClusterId": "todos-cluster",
                "Match": {
                    "Path": "/todos/{id}",
                    "Methods": [ "GET" ]
                }
            }
            // --- FIN Ruta para Todos ---
        },
        "Clusters": {
            "ServicioUsuariosCluster": {
                "Destinations": {
                    "destino1_servicio_usuarios": {
                        // Dirección actualizada al puerto 5263
                        "Address": "http://localhost:5263/"
                    }
                }
            },
            // --- Cluster para Todos (JSONPlaceholder) ---
            "todos-cluster": {
                "Destinations": {
                    "todos-backend": {
                        "Address": "https://jsonplaceholder.typicode.com/"
                    }
                }
            }
            // --- FIN Cluster para Todos ---
        }
    }
}